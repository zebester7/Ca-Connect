rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isVerifiedUser() { return isSignedIn() && request.auth.token.email_verified == true; }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.fullName is string && data.fullName.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               data.role in ['student', 'senior', 'alumni', 'faculty', 'moderator', 'admin'];
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.accountStatus == 'active' || isOwner(userId));
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().createdAt == request.time && 
                    incoming().updatedAt == request.time &&
                    incoming().verificationStatus == 'pending' &&
                    incoming().accountStatus == 'active';
      
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().updatedAt == request.time &&
                    incoming().email == existing().email &&
                    incoming().role == existing().role && // Role immutable by user
                    incoming().accountStatus == existing().accountStatus &&
                    incoming().verificationStatus == existing().verificationStatus &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'username', 'bio', 'profilePhotoUrl', 'caLevel', 'attempt', 'city', 'country', 'updatedAt']);
    }

    // --- Posts Rules ---
    match /posts/{postId} {
      function isValidPost(data) {
        return data.content is string && data.content.size() <= 5000 &&
               data.authorId == request.auth.uid;
      }

      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidPost(incoming()) && 
                    incoming().createdAt == request.time;
      allow update: if isVerifiedUser() && isOwner(existing().authorId) && 
                    isValidPost(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().authorId == existing().authorId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaUrls', 'updatedAt', 'visibility', 'tags']);
      allow delete: if isOwner(existing().authorId);
    }

    // --- Groups Rules ---
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && incoming().createdBy == request.auth.uid;
      // Admin update only in MVP or creator for basic settings
      allow update: if isVerifiedUser() && existing().createdBy == request.auth.uid;
    }

    // --- Questions Rules ---
    match /questions/{questionId} {
      function isValidQuestion(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.body is string && data.body.size() <= 10000 &&
               data.authorId == request.auth.uid;
      }

      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && isValidQuestion(incoming());
      allow update: if isVerifiedUser() && isOwner(existing().authorId) &&
                    isValidQuestion(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'body', 'subject', 'caLevel', 'topic', 'status', 'updatedAt']);
    }

    // --- Resources Rules ---
    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser() && incoming().uploadedBy == request.auth.uid;
    }

    // --- Notifications Rules ---
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
    }
  }
}
